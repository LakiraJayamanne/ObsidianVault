# Ignore Obsidian UI state and cache
.obsidian/workspace*
.obsidian/cache

# Ignore Obsidian Git plugin local data
.obsidian/plugins/obsidian-git/data.json

# Ignore Obsidian community plugin settings that change per device
.obsidian/plugins/*/data.json

# Ignore system junk
.DS_Store
Thumbs.db
desktop.ini

# Ignore temporary or trashed files
.trash/